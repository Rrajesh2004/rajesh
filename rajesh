<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:linear-gradient(135deg,#ff758c,#ff7eb3,#ffd194);
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    overflow:hidden;
}

h1{
    color:white;
    margin:15px;
    text-shadow:2px 2px 10px #000;
}

.book{
    width:360px;
    height:520px;
    background:white;
    border-radius:15px;
    overflow:hidden;
    box-shadow:0 15px 40px rgba(0,0,0,.4);
    position:relative;
}

.slide{
    position:absolute;
    width:100%;
    height:100%;
    display:none;
}

.slide.active{
    display:block;
    animation:fade .8s;
}

.slide img{
    width:100%;
    height:70%;
    object-fit:cover;
}

.text{
    padding:20px;
    text-align:center;
}

.text h2{
    color:#ff3b6c;
    margin-bottom:10px;
}

.text p{
    color:#555;
    line-height:1.7;
    font-style:italic;
}

.buttons{
    margin-top:20px;
}

button{
    padding:12px 25px;
    margin:5px;
    border:none;
    border-radius:30px;
    background:white;
    color:#ff3b6c;
    font-size:17px;
    cursor:pointer;
    font-weight:bold;
}

button:hover{
    background:#ff3b6c;
    color:white;
}

@keyframes fade{
    from{opacity:0;}
    to{opacity:1;}
}

.heart{
    position:absolute;
    color:white;
    animation:float 8s linear infinite;
    font-size:20px;
}

@keyframes float{
    from{
        transform:translateY(100vh);
        opacity:1;
    }
    to{
        transform:translateY(-100px);
        opacity:0;
    }
}
</style>
</head>

